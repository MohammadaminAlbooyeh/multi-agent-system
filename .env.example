# =============================================================================
# MARES — Multi-Agent Research & Execution System
# Environment configuration template. Copy to `.env` and fill in your values.
# =============================================================================

# ---- LLM Provider API Keys --------------------------------------------------
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk-...
OLLAMA_BASE_URL=http://localhost:11434

# ---- LLM Selection ---------------------------------------------------------
# Default provider used by the factory: openai | anthropic | groq | ollama
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4o-mini

# ---- Database --------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://mares:mares@localhost:5432/mares
REDIS_URL=redis://localhost:6379/0

# ---- Orchestrator ----------------------------------------------------------
MAX_CONCURRENT_TASKS=5
TASK_TIMEOUT_SECONDS=120
MAX_RETRIES=3

# ---- Cost Control -----------------------------------------------------------
# Per-agent token budget (input + output combined)
TOKEN_BUDGET_PLANNER=8000
TOKEN_BUDGET_RESEARCH=12000
TOKEN_BUDGET_EXECUTION=8000
TOKEN_BUDGET_CRITIC=6000
TOKEN_BUDGET_SYNTHESIZER=10000
TOKEN_BUDGET_GLOBAL=50000

# ---- Tool Configuration -----------------------------------------------------
SERPAPI_API_KEY=
SEARCH_TIMEOUT_SECONDS=30
PYTHON_SANDBOX_TIMEOUT_SECONDS=10
TOOL_FAILURE_RATE=0.0

# ---- API --------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_LOG_LEVEL=info
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ---- Logging ---------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=logs/mares.log
